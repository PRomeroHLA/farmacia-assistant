# Copiar a .env y ajustar valores. No subir .env a git.
#
# Modo de persistencia: "memory" (por defecto) o "postgresql"
STORAGE_BACKEND=memory
#
# Solo cuando STORAGE_BACKEND=postgresql:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/farmacia_db
#
# JWT (login). En producción usar un secret seguro.
JWT_SECRET_KEY=change-me-in-production
# JWT_EXPIRE_MINUTES=60
