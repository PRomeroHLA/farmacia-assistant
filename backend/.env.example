# Copiar a .env y ajustar valores. No subir .env a git.
#
# Modo de persistencia: "memory" (por defecto) o "postgresql"
STORAGE_BACKEND=memory
#
# Base de datos (PostgreSQL)
# - Cuando STORAGE_BACKEND=memory: DATABASE_URL puede omitirse y no se abrirá conexión a PostgreSQL.
# - Cuando STORAGE_BACKEND=postgresql: DATABASE_URL debe definirse. Driver recomendado: asyncpg.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/farmacia_db
#
# JWT (login). En producción usar un secret seguro.
JWT_SECRET_KEY=change-me-in-production
# JWT_EXPIRE_MINUTES=60
#
# CORS: orígenes permitidos (separados por coma). En desarrollo el front suele estar en 5173 (Vite) y el back en 8000.
# CORS_ORIGINS=http://localhost:5173
#
# OpenAI y extractor de caso (LLM). Por defecto mock; LLM_EXTRACTOR=openai requiere OPENAI_API_KEY.
# OPENAI_API_KEY=sk-proj-
# OPENAI_MODEL=
# LLM_EXTRACTOR=mock
